{
  // ============================================================================
  // THERION PROTOCOL v7.0 -- VS CODE CONFIGURATION
  // ============================================================================
  // Deep Purple/Indigo with Gold Accents
  // When you see these colors, THERION is active.
  // ============================================================================

  // ---------------------------------------------------------------------------
  // WORKBENCH -- THERION COLOR SCHEME
  // ---------------------------------------------------------------------------

  "workbench.colorTheme": "Default Dark Modern",
  "workbench.iconTheme": "vs-seti",
  "workbench.colorCustomizations": {
    "activityBar.background": "#1a1a2e",
    "activityBar.foreground": "#e4b84f",
    "activityBar.activeBorder": "#e4b84f",
    "activityBar.inactiveForeground": "#6c6c8a",

    "sideBar.background": "#16162a",
    "sideBar.foreground": "#c5c5d0",
    "sideBarTitle.foreground": "#e4b84f",
    "sideBarSectionHeader.background": "#1f1f3a",
    "sideBarSectionHeader.foreground": "#e4b84f",

    "titleBar.activeBackground": "#0f0f1a",
    "titleBar.activeForeground": "#e4b84f",
    "titleBar.inactiveBackground": "#0f0f1a",
    "titleBar.inactiveForeground": "#6c6c8a",

    "editor.background": "#12121e",
    "editor.foreground": "#d4d4e0",
    "editor.lineHighlightBackground": "#1a1a30",
    "editor.selectionBackground": "#3d3d6066",
    "editorCursor.foreground": "#e4b84f",
    "editorLineNumber.foreground": "#4a4a6a",
    "editorLineNumber.activeForeground": "#e4b84f",

    "editorWidget.background": "#1a1a2e",
    "editorWidget.border": "#3d3d5a",
    "editorSuggestWidget.background": "#1a1a2e",
    "editorSuggestWidget.border": "#3d3d5a",
    "editorSuggestWidget.selectedBackground": "#2a2a4a",

    "tab.activeBackground": "#1a1a2e",
    "tab.activeForeground": "#e4b84f",
    "tab.inactiveBackground": "#12121e",
    "tab.inactiveForeground": "#6c6c8a",
    "tab.activeBorder": "#e4b84f",
    "tab.hoverBackground": "#22223a",

    "statusBar.background": "#0f0f1a",
    "statusBar.foreground": "#c5c5d0",
    "statusBar.debuggingBackground": "#4a1a4a",
    "statusBar.noFolderBackground": "#1a1a2e",

    "terminal.background": "#0f0f1a",
    "terminal.foreground": "#d4d4e0",
    "terminalCursor.foreground": "#e4b84f",

    "button.background": "#4a3a7a",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#5a4a8a",

    "list.activeSelectionBackground": "#2a2a4a",
    "list.activeSelectionForeground": "#e4b84f",
    "list.hoverBackground": "#1f1f3a",
    "list.focusBackground": "#2a2a4a",

    "input.background": "#1a1a2e",
    "input.border": "#3d3d5a",
    "input.foreground": "#d4d4e0",
    "inputOption.activeBorder": "#e4b84f",

    "panel.background": "#12121e",
    "panel.border": "#3d3d5a",
    "panelTitle.activeBorder": "#e4b84f",
    "panelTitle.activeForeground": "#e4b84f",

    "notifications.background": "#1a1a2e",
    "notifications.border": "#3d3d5a",

    "focusBorder": "#e4b84f"
  },

  // ---------------------------------------------------------------------------
  // COPILOT / AI ASSISTANT
  // ---------------------------------------------------------------------------

  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "json": true,
    "jsonc": true
  },
  "github.copilot.chat.localeOverride": "en",
  "github.copilot.chat.followUps": "always",
  "chat.agent.enabled": true,

  // ---------------------------------------------------------------------------
  // EDITOR
  // ---------------------------------------------------------------------------

  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.formatOnType": false,
  "editor.suggest.showWords": false,
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.wordBasedSuggestions": "off",
  "editor.inlineSuggest.enabled": true,
  "editor.linkedEditing": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 2,
  "editor.renderWhitespace": "boundary",
  "editor.accessibilitySupport": "off",
  "editor.wordWrap": "on",

  // ---------------------------------------------------------------------------
  // MARKDOWN
  // ---------------------------------------------------------------------------

  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },
  "markdown.preview.breaks": true,
  "markdown.preview.linkify": true,

  // ---------------------------------------------------------------------------
  // FILES
  // ---------------------------------------------------------------------------

  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.next/**": true
  },

  // ---------------------------------------------------------------------------
  // SEARCH
  // ---------------------------------------------------------------------------

  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/.next": true,
    "**/__pycache__": true
  },

  // ---------------------------------------------------------------------------
  // TERMINAL
  // ---------------------------------------------------------------------------

  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,

  // ---------------------------------------------------------------------------
  // TYPESCRIPT / JAVASCRIPT
  // ---------------------------------------------------------------------------

  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.suggest.completeFunctionCalls": true,
  "typescript.preferences.importModuleSpecifier": "relative",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "javascript.suggest.completeFunctionCalls": true,

  // ---------------------------------------------------------------------------
  // PYTHON
  // ---------------------------------------------------------------------------

  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  // ---------------------------------------------------------------------------
  // FORMATTING (PRETTIER)
  // ---------------------------------------------------------------------------

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true
  },

  // ---------------------------------------------------------------------------
  // GIT
  // ---------------------------------------------------------------------------

  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",

  // ---------------------------------------------------------------------------
  // EXPLORER
  // ---------------------------------------------------------------------------

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "explorer.sortOrder": "type",

  // ---------------------------------------------------------------------------
  // WORKBENCH
  // ---------------------------------------------------------------------------

  "workbench.startupEditor": "none",
  "workbench.tree.indent": 16,
  "workbench.editor.enablePreview": true,
  "workbench.editor.tabSizing": "shrink",

  // ---------------------------------------------------------------------------
  // TELEMETRY (DISABLED)
  // ---------------------------------------------------------------------------

  "telemetry.telemetryLevel": "off"
}
