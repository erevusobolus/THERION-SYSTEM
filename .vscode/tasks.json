{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "THERION: Python Venv Setup",
      "type": "shell",
      "command": "python",
      "args": ["-m", "venv", ".venv"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "THERION: Install Python Dependencies",
      "type": "shell",
      "command": "pip",
      "args": ["install", "-r", "requirements.txt"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "THERION: Run Python Tests",
      "type": "shell",
      "command": "python",
      "args": ["-m", "pytest", "-v"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "THERION: Type Check (TypeScript)",
      "type": "shell",
      "command": "npx",
      "args": ["tsc", "--noEmit"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "THERION: Lint (ESLint)",
      "type": "shell",
      "command": "npx",
      "args": ["eslint", ".", "--ext", ".ts,.tsx,.js,.jsx", "--fix"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "THERION: Format (Prettier)",
      "type": "shell",
      "command": "npx",
      "args": ["prettier", "--write", "."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
